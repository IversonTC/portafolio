---
// Layout.astro
import "../styles/global.css";
import "@fortawesome/fontawesome-free/css/all.min.css";
const { title = "Portafolio | Iverson" } = Astro.props;
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;800&display=swap" rel="stylesheet" />
  </head>

  <body class="bg-[#080b14] text-slate-200 font-['Plus_Jakarta_Sans',sans-serif] selection:bg-violet-500/30">
    <slot />
  </body>
</html>